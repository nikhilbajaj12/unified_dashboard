{
  "uid": "workflow-execution",
  "title": "Workflow Execution (Temporal)",
  "tags": ["temporal", "workflows"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "custom",
        "query": "zenarc,retail-onboarding",
        "options": [
          {"selected": true, "text": "zenarc", "value": "zenarc"},
          {"selected": false, "text": "retail-onboarding", "value": "retail-onboarding"}
        ],
        "current": {"selected": true, "text": "zenarc", "value": "zenarc"},
        "multi": false,
        "includeAll": false,
        "sort": 0,
        "refresh": 0,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Workflows",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(temporal_workflow_active{namespace=\"${namespace}\"})",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }
      }
    },
    {
      "id": 2,
      "title": "Workflow States",
      "type": "piechart",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "temporal_workflow_active{namespace=\"${namespace}\"}",
          "legendFormat": "Running"
        },
        {
          "expr": "temporal_workflow_completed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Completed"
        },
        {
          "expr": "temporal_workflow_failed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Failed"
        },
        {
          "expr": "temporal_workflow_timed_out_total{namespace=\"${namespace}\"}",
          "legendFormat": "Timed Out"
        },
        {
          "expr": "temporal_workflow_canceled_total{namespace=\"${namespace}\"}",
          "legendFormat": "Canceled"
        }
      ],
      "options": { "pieType": "donut" }
    },
    {
      "id": 3,
      "title": "Workflow Failure Rate",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "temporal_workflow_failed_total{namespace=\"${namespace}\"} / (temporal_workflow_failed_total{namespace=\"${namespace}\"} + temporal_workflow_completed_total{namespace=\"${namespace}\"} + temporal_workflow_active{namespace=\"${namespace}\"}) * 100",
          "legendFormat": "Failure Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Workflow Counts Over Time",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "temporal_workflow_active{namespace=\"${namespace}\"}",
          "legendFormat": "Running"
        },
        {
          "expr": "temporal_workflow_completed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Completed"
        },
        {
          "expr": "temporal_workflow_failed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Failed"
        },
        {
          "expr": "temporal_workflow_canceled_total{namespace=\"${namespace}\"}",
          "legendFormat": "Canceled"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 5,
      "title": "Timed Out & Canceled Workflows",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "temporal_workflow_timed_out_total{namespace=\"${namespace}\"}",
          "legendFormat": "Timed Out"
        },
        {
          "expr": "temporal_workflow_canceled_total{namespace=\"${namespace}\"}",
          "legendFormat": "Canceled"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "Workflow Status Summary",
      "type": "table",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "temporal_workflow_active{namespace=\"${namespace}\"}",
          "legendFormat": "Running",
          "instant": true
        },
        {
          "expr": "temporal_workflow_completed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Completed",
          "instant": true
        },
        {
          "expr": "temporal_workflow_failed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Failed",
          "instant": true
        },
        {
          "expr": "temporal_workflow_timed_out_total{namespace=\"${namespace}\"}",
          "legendFormat": "Timed Out",
          "instant": true
        },
        {
          "expr": "temporal_workflow_canceled_total{namespace=\"${namespace}\"}",
          "legendFormat": "Canceled",
          "instant": true
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    },
    {
      "id": 7,
      "title": "Total Workflows by Status",
      "type": "bargauge",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "temporal_workflow_active{namespace=\"${namespace}\"}",
          "legendFormat": "Running",
          "instant": true
        },
        {
          "expr": "temporal_workflow_completed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Completed",
          "instant": true
        },
        {
          "expr": "temporal_workflow_failed_total{namespace=\"${namespace}\"}",
          "legendFormat": "Failed",
          "instant": true
        },
        {
          "expr": "temporal_workflow_timed_out_total{namespace=\"${namespace}\"}",
          "legendFormat": "Timed Out",
          "instant": true
        },
        {
          "expr": "temporal_workflow_canceled_total{namespace=\"${namespace}\"}",
          "legendFormat": "Canceled",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    }
  ]
}
