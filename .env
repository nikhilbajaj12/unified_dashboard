# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Alerts (optional)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- Phoenix OSS (Local container on port 6006) ---
# PHOENIX_BASE_URL is set per-service in docker-compose for inter-container networking.
# Set PHOENIX_API_KEY only if you enabled auth on Phoenix OSS (PHOENIX_SECRET set in phoenix env).
# For Phoenix Cloud / Arize-managed Phoenix, paste your API key here:
PHOENIX_BASE_URL=https://zaf-phoenix.bravesky-d9f9eeb7.eastus2.azurecontainerapps.io
PHOENIX_OTLP_ENDPOINT=https://zaf-phoenix.bravesky-d9f9eeb7.eastus2.azurecontainerapps.io
PHOENIX_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiJBcGlLZXk6MSJ9.PW-Dq35UwThFYSElOJnJuz7tG6Ta709yQpOJOrp0MTA

# --- Temporal ---
# For local Temporal server leave TEMPORAL_HOST as-is.
# For Temporal Cloud set TEMPORAL_HOST to <namespace>.<accountId>.tmprl.cloud:7233
# and paste your Temporal Cloud API token in TEMPORAL_API_KEY.
TEMPORAL_HOST=localhost:7233
TEMPORAL_BASE_URL=https://temporal-ui.bravesky-d9f9eeb7.eastus2.azurecontainerapps.io
TEMPORAL_NAMESPACE=zenarc
TEMPORAL_API_KEY=

